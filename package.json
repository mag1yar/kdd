{
  "name": "kddkit-monorepo",
  "private": true,
  "description": "KDD — kanban + memory substrate for humans and Claude.",
  "author": {
    "name": "kddkit",
    "url": "https://github.com/mag1yar"
  },
  "license": "MIT",
  "homepage": "https://github.com/mag1yar/kddkit",
  "repository": {
    "type": "git",
    "url": "https://github.com/mag1yar/kddkit.git"
  },
  "packageManager": "pnpm@11.0.9",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "bumpp": "^11.1.0",
    "turbo": "^2.10.5",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "dev:cli": "KDD_HOME=$HOME/.kdd-dev node packages/cli/dist/index.js",
    "dev:ui": "KDD_HOME=$HOME/.kdd-dev node packages/cli/dist/index.js ui --port 4488",
    "release": "bumpp package.json packages/*/package.json .claude-plugin/plugin.json --all --no-push --execute \"turbo run build test\" && pnpm -r publish"
  }
}
